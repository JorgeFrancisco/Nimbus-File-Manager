<?xml version="1.0" encoding="UTF-8"?>
<project
	xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.5.16</version>
		<relativePath/>
	</parent>
	<groupId>br.com.jorgemelo</groupId>
	<artifactId>nimbus-file-manager</artifactId>
	<version>5.0.1.27</version>
	<name>Nimbus File Manager</name>
	<description>Local-first file management application for continuously inventorying,
    monitoring, enriching, organizing and auditing personal files.</description>
	<properties>
		<java.version>25</java.version>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
		<maven.resources.encoding>UTF-8</maven.resources.encoding>
		<argLine/>
		<springdoc.version>2.8.14</springdoc.version>
		<lombok.version>1.18.46</lombok.version>
		<metadata-extractor.version>2.19.0</metadata-extractor.version>
		<pitest.version>1.25.6</pitest.version>
		<pitest-junit5-plugin.version>1.2.3</pitest-junit5-plugin.version>
		<zxing.version>3.5.3</zxing.version>
		<bootstrap-icons.version>1.13.1</bootstrap-icons.version>
		<leaflet.version>1.9.4</leaflet.version>
		<jts.version>1.20.0</jts.version>
		<twelvemonkeys.version>3.12.0</twelvemonkeys.version>
		<sonar-maven-plugin.version>5.7.0.6970</sonar-maven-plugin.version>
		<!-- SonarQube / SonarScanner. projectKey/projectName/host.url/token can also be
		     passed on the command line (CLI wins); kept here so a bare `mvn sonar:sonar`
		     works and the run is reproducible. -->
		<sonar.host.url>http://localhost:9000</sonar.host.url>
		<sonar.projectKey>Nimbus-File-Manager</sonar.projectKey>
		<sonar.projectName>Nimbus-File-Manager</sonar.projectName>
		<sonar.sourceEncoding>${project.build.sourceEncoding}</sonar.sourceEncoding>
		<sonar.java.source>${java.version}</sonar.java.source>
		<!-- Coverage: Sonar reads JaCoCo's XML report (produced in the test phase). -->
		<sonar.coverage.jacoco.xmlReportPaths>${project.build.directory}/site/jacoco/jacoco.xml</sonar.coverage.jacoco.xmlReportPaths>
		<sonar.junit.reportPaths>${project.build.directory}/surefire-reports</sonar.junit.reportPaths>
		<!-- Mirror the JaCoCo <excludes> so Sonar's coverage matches the project's:
		     bootstrap, Spring wiring, data-only classes (entities/DTOs), the repository
		     layer, external-process glue and the HTTP download adapter are covered by
		     integration/manual checks, not units. Issues are still analysed on them;
		     only coverage is excluded. -->
		<sonar.coverage.exclusions>**/NimbusFileManagerApplication.java,**/infrastructure/config/**,**/domain/model/**,**/dto/**,**/application/constants/**,**/*Constants.java,**/repository/**,**/*Repository.java,**/*ProcessRunner.java,**/GeoBoundariesSource.java,**/windows/**</sonar.coverage.exclusions>
		<!-- The Windows-only FFM glue (USN journal + ReadDirectoryChangesW) in the
		     ".../source/**/windows" subpackages is native interop: the java.lang.foreign
		     downcalls mirror the Win32 ABI (DeviceIoControl's 8 params, PascalCase kernel32
		     symbols) and it runs only on Windows. Java static-analysis conventions do not
		     apply, and it is validated by conditional integration tests and manual runs, so
		     those subpackages (production + their ITs) are excluded from analysis. Only they
		     are excluded - all the pure logic above them stays analysed and unit-tested. -->
		<sonar.exclusions>**/windows/**</sonar.exclusions>
		<sonar.test.exclusions>**/windows/**</sonar.test.exclusions>
	</properties>
	<dependencies>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-thymeleaf</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-security</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-oauth2-client</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-mail</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-batch</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
		</dependency>
		<dependency>
			<groupId>org.webjars.npm</groupId>
			<artifactId>bootstrap-icons</artifactId>
			<version>${bootstrap-icons.version}</version>
		</dependency>
		<dependency>
			<groupId>org.webjars.npm</groupId>
			<artifactId>leaflet</artifactId>
			<version>${leaflet.version}</version>
		</dependency>
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
			<scope>runtime</scope>
		</dependency>
		<dependency>
			<groupId>org.springdoc</groupId>
			<artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
			<version>${springdoc.version}</version>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.springframework.security</groupId>
			<artifactId>spring-security-test</artifactId>
			<scope>test</scope>
		</dependency>
		<!-- Testcontainers: the @SpringBootTest integration tests spin up a throwaway
		     PostgreSQL container (via @ServiceConnection) instead of a shared external DB,
		     so each test class is isolated and they can run in parallel. Versions come from
		     the Spring Boot BOM. Requires Docker on the machine/CI runner. -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-testcontainers</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>junit-jupiter</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.testcontainers</groupId>
			<artifactId>postgresql</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.flywaydb</groupId>
			<artifactId>flyway-core</artifactId>
		</dependency>
		<dependency>
			<groupId>org.flywaydb</groupId>
			<artifactId>flyway-database-postgresql</artifactId>
		</dependency>
		<dependency>
			<groupId>org.projectlombok</groupId>
			<artifactId>lombok</artifactId>
			<optional>true</optional>
		</dependency>
		<dependency>
			<groupId>com.drewnoakes</groupId>
			<artifactId>metadata-extractor</artifactId>
			<version>${metadata-extractor.version}</version>
		</dependency>
		<dependency>
			<groupId>com.twelvemonkeys.imageio</groupId>
			<artifactId>imageio-core</artifactId>
			<version>${twelvemonkeys.version}</version>
		</dependency>
		<dependency>
			<groupId>com.twelvemonkeys.imageio</groupId>
			<artifactId>imageio-webp</artifactId>
			<version>${twelvemonkeys.version}</version>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-configuration-processor</artifactId>
			<optional>true</optional>
		</dependency>
		<dependency>
			<groupId>commons-codec</groupId>
			<artifactId>commons-codec</artifactId>
			<version>1.18.0</version><!--$NO-MVN-MAN-VER$-->
		</dependency>
		<dependency>
			<groupId>com.google.zxing</groupId>
			<artifactId>javase</artifactId>
			<version>${zxing.version}</version>
		</dependency>
		<dependency>
			<groupId>org.apache.tika</groupId>
			<artifactId>tika-core</artifactId>
			<version>3.2.2</version>
		</dependency>
		<dependency>
			<groupId>org.locationtech.jts</groupId>
			<artifactId>jts-core</artifactId>
			<version>${jts.version}</version>
		</dependency>
		<!-- Disabled because automatic restarts can interfere with concurrent IDE edits.
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-devtools</artifactId>
			<scope>runtime</scope>
			<optional>true</optional>
		</dependency>
		-->
	</dependencies>
	<build>
		<!--
			No <resources> override on purpose: spring-boot-starter-parent already filters ONLY
			application*.properties/yml/yaml (with the @...@ delimiter) and copies every other
			resource byte-for-byte. A blanket <filtering>true</filtering> re-encodes the UTF-8
			templates and, on Windows/m2e, double-encodes accents (ç -> Ã§). Inheriting the
			parent avoids that and also covers profile files (application-dev.properties, .yml).
		-->
		<pluginManagement>
			<plugins>
				<!-- Pin the SonarScanner version so `sonar:sonar` is reproducible instead
				     of resolving the latest release at run time. -->
				<plugin>
					<groupId>org.sonarsource.scanner.maven</groupId>
					<artifactId>sonar-maven-plugin</artifactId>
					<version>${sonar-maven-plugin.version}</version>
				</plugin>
			</plugins>
		</pluginManagement>
		<plugins>
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
				<executions>
					<execution>
						<goals>
							<goal>repackage</goal>
						</goals>
					</execution>
				</executions>
				<!-- spring-boot:run executes from the exploded classpath, so the packaged jar's
				     Enable-Native-Access manifest entry does not apply; pass the flag here so the
				     Windows FFM change source (WindowsKernel32) runs without the restricted-method
				     warning. -->
				<configuration>
					<jvmArguments>--enable-native-access=ALL-UNNAMED</jvmArguments>
				</configuration>
			</plugin>
			<!-- Declares that the app uses the Foreign Function & Memory API to reach kernel32
			     (the Windows change source), so `java -jar` runs without the Java 25 restricted
			     native-access warning and stays ready for future JDKs that deny it by default.
			     Set on the intermediate jar; spring-boot:repackage preserves existing manifest
			     entries, so it carries over to the final executable jar. Version comes from the
			     spring-boot-starter-parent. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<configuration>
					<archive>
						<manifestEntries>
							<Enable-Native-Access>ALL-UNNAMED</Enable-Native-Access>
						</manifestEntries>
					</archive>
				</configuration>
			</plugin>
			<!-- Build-time guard: after repackage, read the final executable jar's manifest and
			     fail the build if the native-access declaration or the Spring Boot launcher entries
			     drifted. Bound to package and declared after spring-boot-maven-plugin, so it runs on
			     the repackaged jar (not the intermediate one). Version comes from the parent. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-antrun-plugin</artifactId>
				<executions>
					<execution>
						<id>verify-executable-jar-manifest</id>
						<phase>package</phase>
						<goals>
							<goal>run</goal>
						</goals>
						<configuration>
							<target>
								<loadresource property="executable.jar.manifest">
									<zipentry zipfile="${project.build.directory}/${project.build.finalName}.jar"
										name="META-INF/MANIFEST.MF" />
								<!-- Un-wrap MANIFEST.MF 72-byte line continuations (CRLF + leading space) so the
								     Start-Class check below still matches when a long fully-qualified class name is
								     split across a continuation line. -->
								<filterchain>
									<tokenfilter>
										<filetokenizer />
										<replaceregex pattern="\r?\n " replace="" flags="gs" />
									</tokenfilter>
								</filterchain>
								</loadresource>
								<fail
									message="Executable jar manifest is missing 'Enable-Native-Access: ALL-UNNAMED'.">
									<condition>
										<not>
											<contains string="${executable.jar.manifest}"
												substring="Enable-Native-Access: ALL-UNNAMED" />
										</not>
									</condition>
								</fail>
								<fail
									message="Executable jar manifest lost the Spring Boot 'Main-Class' launcher entry.">
									<condition>
										<not>
											<contains string="${executable.jar.manifest}"
												substring="Main-Class: org.springframework.boot.loader" />
										</not>
									</condition>
								</fail>
								<fail
									message="Executable jar manifest lost the Spring Boot 'Start-Class' entry.">
									<condition>
										<not>
											<contains string="${executable.jar.manifest}"
												substring="Start-Class: br.com.jorgemelo.nimbusfilemanager.NimbusFileManagerApplication" />
										</not>
									</condition>
								</fail>
								<echo
									message="Verified executable jar manifest: Enable-Native-Access + Spring Boot launcher entries present." />
							</target>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.14.0</version><!--$NO-MVN-MAN-VER$-->
				<configuration>
					<release>${java.version}</release>
					<encoding>${project.build.sourceEncoding}</encoding>
					<annotationProcessorPaths>
						<path>
							<groupId>org.projectlombok</groupId>
							<artifactId>lombok</artifactId>
							<version>${lombok.version}</version>
						</path>
					</annotationProcessorPaths>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-resources-plugin</artifactId>
				<version>3.3.1</version><!--$NO-MVN-MAN-VER$-->
				<configuration>
					<encoding>${project.build.sourceEncoding}</encoding>
					<propertiesEncoding>${project.build.sourceEncoding}</propertiesEncoding>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<version>3.5.3</version><!--$NO-MVN-MAN-VER$-->
				<configuration>
					<argLine>@{argLine} -Dfile.encoding=${project.build.sourceEncoding}</argLine>
					<!-- Disable the folder-watch poll loop in the test JVM. No @SpringBootTest
					     exercises it, so its 500ms DB poll only wastes cycles and races the
					     Testcontainers/Hikari teardown at JVM exit (EOFException, "connection is
					     closed", ~30s hang, Surefire fork kill). Production keeps the default. -->
					<systemPropertyVariables>
						<nimbus-file-manager.inventory.watch.enabled>false</nimbus-file-manager.inventory.watch.enabled>
					</systemPropertyVariables>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.jacoco</groupId>
				<artifactId>jacoco-maven-plugin</artifactId>
				<version>0.8.13</version>
				<configuration>
					<excludes>
						<exclude>br/com/jorgemelo/nimbusfilemanager/NimbusFileManagerApplication.class</exclude>
						<exclude>**/infrastructure/config/**</exclude>
						<exclude>**/domain/model/**</exclude>
						<exclude>br/com/jorgemelo/nimbusfilemanager/**/dto/**</exclude>
						<!-- Data-only constant holders (public static final fields + private ctor,
						     no logic) live in each domain's application/constants package (a general
						     <Domain>Constants plus dedicated cohesive holders like ExecutionMessages,
						     WorkspaceFolders); like DTOs there is nothing meaningful to cover. -->
						<exclude>**/application/constants/**</exclude>
						<exclude>**/*Constants.class</exclude>
						<exclude>**/repository/**</exclude>
						<exclude>**/*Repository.class</exclude>
						<!-- External-process glue (ffmpeg/exiftool/mediainfo spawn + stream draining):
						     cannot be meaningfully unit-tested, so it lives in dedicated *ProcessRunner
						     classes that are excluded here. Pure logic stays in the owning service. -->
						<exclude>**/*ProcessRunner.class</exclude>
						<!-- HTTP download adapter for the geoBoundaries dataset (client + ETag + network
						     IO). Like the process glue it is external-integration only (needs the real
						     API / a mock HTTP server), so it is covered by integration tests, not units. -->
						<exclude>**/GeoBoundariesSource.class</exclude>
						<!-- Windows-only FFM glue (kernel32 DeviceIoControl / OpenFileById /
						     ReadDirectoryChangesW via java.lang.foreign) in the ".../source/**/windows"
						     subpackages. Cannot run on the Linux CI, so it is covered by conditional
						     integration tests and manual runs; all the logic above it
						     (parsers/interpreters/sources/cursor/selection) is unit-tested. -->
						<exclude>**/windows/**</exclude>
					</excludes>
				</configuration>
				<executions>
					<execution>
						<id>prepare-agent</id>
						<goals>
							<goal>prepare-agent</goal>
						</goals>
					</execution>
					<execution>
						<id>report</id>
						<phase>test</phase>
						<goals>
							<goal>report</goal>
						</goals>
						<configuration>
							<formats>
								<format>HTML</format>
								<format>XML</format>
							</formats>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.5.0</version>
				<executions>
					<execution>
						<id>quality-summary</id>
						<phase>test</phase>
						<goals>
							<goal>java</goal>
						</goals>
						<configuration>
							<mainClass>br.com.jorgemelo.nimbusfilemanager.quality.QualitySummary</mainClass>
							<classpathScope>test</classpathScope>
							<cleanupDaemonThreads>false</cleanupDaemonThreads>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>
	<profiles>
		<profile>
			<id>pitest</id>
			<build>
				<plugins>
					<plugin>
						<groupId>org.pitest</groupId>
						<artifactId>pitest-maven</artifactId>
						<version>${pitest.version}</version>
						<dependencies>
							<dependency>
								<groupId>org.pitest</groupId>
								<artifactId>pitest-junit5-plugin</artifactId>
								<version>${pitest-junit5-plugin.version}</version>
							</dependency>
						</dependencies>
						<configuration>
							<targetClasses>
								<param>br.com.jorgemelo.nimbusfilemanager.*</param>
							</targetClasses>
							<targetTests>
								<param>br.com.jorgemelo.nimbusfilemanager.*</param>
							</targetTests>
							<excludedClasses>
								<param>br.com.jorgemelo.nimbusfilemanager.NimbusFileManagerApplication</param>
								<param>br.com.jorgemelo.nimbusfilemanager.config.*</param>
								<param>br.com.jorgemelo.nimbusfilemanager.domain.entity.*</param>
								<param>br.com.jorgemelo.nimbusfilemanager.dto.request.*</param>
								<param>br.com.jorgemelo.nimbusfilemanager.dto.response.*</param>
							</excludedClasses>
							<outputFormats>
								<param>HTML</param>
								<param>XML</param>
							</outputFormats>
							<timestampedReports>false</timestampedReports>
							<withHistory>false</withHistory>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>
</project>